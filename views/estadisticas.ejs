<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Estadísticas</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: Arial, sans-serif; background: #f5f0eb; min-height: 100vh; padding: 40px 20px; }
        h1 { text-align: center; color: #3d2b1f; font-size: 2rem; margin-bottom: 10px; }
        .subtitulo { text-align: center; color: #7a5c44; margin-bottom: 40px; }
        .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 20px; max-width: 900px; margin: 0 auto 40px; }
        .card { background: white; border-radius: 10px; padding: 24px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); text-align: center; border-top: 4px solid #3d2b1f; }
        .card .numero { font-size: 2.5rem; font-weight: bold; color: #3d2b1f; margin-bottom: 8px; }
        .card .etiqueta { color: #7a5c44; font-size: 0.95rem; }
        .estados { max-width: 900px; margin: 0 auto 40px; background: white; border-radius: 10px; padding: 30px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); }
        .estados h2 { color: #3d2b1f; margin-bottom: 20px; }
        .barra-contenedor { margin-bottom: 16px; }
        .barra-label { display: flex; justify-content: space-between; color: #7a5c44; font-size: 0.9rem; margin-bottom: 6px; }
        .barra { height: 12px; background: #f0e6d3; border-radius: 6px; overflow: hidden; }
        .barra-relleno { height: 100%; border-radius: 6px; transition: width 0.5s; }
        .pendiente { background: #e67e22; }
        .leyendo { background: #2ecc71; }
        .terminado { background: #3498db; }
        .btn-volver { display: block; width: fit-content; margin: 0 auto; background: #3d2b1f; color: white; padding: 10px 24px; border-radius: 6px; text-decoration: none; }
    </style>
</head>
<body>

    <h1>📊 Estadísticas</h1>
    <p class="subtitulo">Un vistazo a tu estantería</p>

    <!-- Tarjetas resumen -->
    <div class="grid">
        <div class="card">
            <div class="numero"><%= stats.total %></div>
            <div class="etiqueta">📚 Libros en total</div>
        </div>

        <div class="card">
            <div class="numero"><%= stats.mediaValoracion > 0 ? stats.mediaValoracion + ' ★' : 'N/A' %></div>
            <div class="etiqueta">⭐ Media de valoración</div>
        </div>

        <div class="card">
            <div class="numero"><%= stats.generoFavorito %></div>
            <div class="etiqueta">🏷️ Género más leído</div>
        </div>

        <div class="card">
            <div class="numero"><%= stats.totalConFechas %></div>
            <div class="etiqueta">📅 Libros con fechas registradas</div>
        </div>
    </div>

    <!-- Barras por estado -->
    <div class="estados">
        <h2>📈 Libros por estado</h2>
        <% stats.porEstado.forEach(item => { %>
            <div class="barra-contenedor">
                <div class="barra-label">
                    <span><%= item.estado %></span>
                    <span><%= item.cantidad %> libro<%= item.cantidad !== 1 ? 's' : '' %></span>
                </div>
                <div class="barra">
                    <div class="barra-relleno <%= item.estado %>"
                        data-ancho="<%= stats.total > 0 ? (item.cantidad / stats.total * 100) : 0 %>">
                    </div>
                </div>
            </div>
        <% }) %>
    </div>

    <a class="btn-volver" href="/libros">↩️ Volver a la estantería</a>

    <script>
    document.querySelectorAll('.barra-relleno').forEach(barra => {
        barra.style.width = barra.dataset.ancho + '%';
    });
</script>

</body>
</html>