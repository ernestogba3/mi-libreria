<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title><%= libro.titulo %></title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: Arial, sans-serif; background: #f5f0eb; min-height: 100vh; padding: 40px 20px; }
        .tarjeta { background: white; max-width: 500px; margin: 0 auto; padding: 40px; border-radius: 10px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); border-top: 6px solid #3d2b1f; }
        .titulo { color: #3d2b1f; font-size: 1.8rem; margin-bottom: 8px; }
        .autor { color: #7a5c44; font-size: 1.1rem; margin-bottom: 20px; }
        .badge { display: inline-block; padding: 4px 14px; border-radius: 20px; font-size: 0.9rem; font-weight: bold; margin-bottom: 20px; }
        .pendiente { background: #fdebd0; color: #d35400; }
        .leyendo { background: #d5f5e3; color: #1e8449; }
        .terminado { background: #d6eaf8; color: #1a5276; }
        .estrellas { color: #f0a500; font-size: 1.5rem; margin-bottom: 30px; }
        .acciones { display: flex; gap: 10px; }
        .btn-editar { background: #f0a500; color: white; padding: 8px 16px; border: none; border-radius: 4px; cursor: pointer; text-decoration: none; font-size: 0.95rem; }
        .btn-eliminar { background: #e74c3c; color: white; padding: 8px 16px; border: none; border-radius: 4px; cursor: pointer; font-size: 0.95rem; }
        .btn-volver { display: block; text-align: center; margin-top: 20px; color: #7a5c44; text-decoration: none; }
    </style>
</head>
<body>

    <div class="tarjeta">
        <h1 class="titulo">📖 <%= libro.titulo %></h1>
        <p class="autor">✍️ <%= libro.autor %></p>

        <span class="badge <%= libro.estado %>"><%= libro.estado %></span>

        <p class="estrellas">
            <% for(let i = 1; i <= 5; i++) { %>
                <%= i <= libro.valoracion ? '★' : '☆' %>
            <% } %>
        </p>

        <div class="acciones">
            <a class="btn-editar" href="/libros/<%= libro.id %>/editar">✏️ Editar</a>
            <form action="/libros/<%= libro.id %>?_method=DELETE" method="POST">
                <button class="btn-eliminar" type="submit">🗑️ Eliminar</button>
            </form>
        </div>

        <a class="btn-volver" href="/libros">↩️ Volver a la estantería</a>
    </div>

</body>
</html>