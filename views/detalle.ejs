<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <title>
        <%= libro.titulo %>
    </title>
    <link rel="stylesheet" href="/css/global.css">
    <link rel="stylesheet" href="/css/detalle.css">
</head>

<body>

    <div class="tarjeta">
        <h1 class="titulo">📖 <%= libro.titulo %>
        </h1>
        <p class="autor">✍️ <%= libro.autor %>
        </p>

        <div>
            <span class="badge <%= libro.estado %>">
                <%= libro.estado %>
            </span>
            <!-- 👇 Nuevo: muestra el género si existe -->
            <% if (libro.genero) { %>
                <span class="genero">🏷️ <%= libro.genero %></span>
                <% } %>
        </div>

        <p class="estrellas">
            <% for(let i=1; i <=5; i++) { %>
                <%= i <=libro.valoracion ? '★' : '☆' %>
                    <% } %>
        </p>

        <div class="fechas">
            <span>📅 Inicio: <%= libro.fecha_inicio || 'Sin registrar' %></span>
            <span>🏁 Fin: <%= libro.fecha_fin || 'Sin registrar' %></span>
        </div>

        <!-- Añade esto justo antes de las acciones en detalle.ejs -->
        <% if (libro.notas) { %>
            <div class="notas">
                <h3>📝 Notas personales</h3>
                <p>
                    <%= libro.notas %>
                </p>
            </div>
            <% } %>

                <div class="acciones">
                    <a class="btn-editar" href="/libros/<%= libro.id %>/editar">✏️ Editar</a>
                    <form action="/libros/<%= libro.id %>?_method=DELETE" method="POST">
                        <button class="btn-eliminar" type="submit">🗑️ Eliminar</button>
                    </form>
                </div>

                <a class="btn-volver" href="/libros">↩️ Volver a la estantería</a>
    </div>

</body>

</html>