<!DOCTYPE html>
<html lang="es" data-theme="light">
<head>
    <title><%= libro.titulo %></title>
    <%- include('partials/head') %>
    <link rel="stylesheet" href="/css/detalle.css">
</head>
<body>

    <%- include('partials/nav') %>

    <main class="container">
        <div class="detalle-wrapper">

            <header class="detalle-header">
                <div class="detalle-badges">
                    <span class="badge <%= libro.estado %>"><%= libro.estado %></span>
                    <% if (libro.genero) { %>
                        <span class="badge-genero">🏷️ <%= libro.genero %></span>
                    <% } %>
                </div>

                <h1><%= libro.titulo %></h1>
                <p class="detalle-autor">— <%= libro.autor %></p>

                <p class="estrellas grande">
                    <% for(let i = 1; i <= 5; i++) { %>
                        <%= i <= libro.valoracion ? '★' : '☆' %>
                    <% } %>
                </p>
            </header>

            <div class="detalle-cuerpo">

                <div class="detalle-fechas">
                    <div class="fecha-item">
                        <span class="fecha-label">📅 Inicio</span>
                        <span class="fecha-valor"><%= libro.fecha_inicio || 'Sin registrar' %></span>
                    </div>
                    <div class="fecha-separador">→</div>
                    <div class="fecha-item">
                        <span class="fecha-label">🏁 Fin</span>
                        <span class="fecha-valor"><%= libro.fecha_fin || 'Sin registrar' %></span>
                    </div>
                </div>

                <% if (libro.notas) { %>
                    <div class="detalle-notas">
                        <h3>📝 Notas personales</h3>
                        <p><%= libro.notas %></p>
                    </div>
                <% } %>

            </div>

            <footer class="detalle-acciones">
                <a href="/libros/<%= libro.id %>/editar" role="button" class="outline">✏️ Editar</a>
                <form action="/libros/<%= libro.id %>?_method=DELETE" method="POST">
                    <button class="outline secondary" type="submit">🗑️ Eliminar</button>
                </form>
                <a href="/libros" class="outline secondary">↩️ Volver</a>
            </footer>

        </div>
    </main>

</body>
</html>