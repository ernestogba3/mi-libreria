<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Añadir Libro</title>
    <link rel="stylesheet" href="/css/global.css">
    <link rel="stylesheet" href="/css/formulario.css">
</head>
<body>

    <h1>📖 Añadir nuevo libro</h1>

    <div class="formulario">

        <% if (errores.length > 0) { %>
            <div class="errores">
                <% errores.forEach(error => { %>
                    <p>⚠️ <%= error %></p>
                <% }) %>
            </div>
        <% } %>

        <form action="/libros" method="POST">

            <label>Título</label>
            <input type="text" name="titulo" placeholder="Título del libro"
                value="<%= typeof datos !== 'undefined' ? datos.titulo : '' %>" required>

            <label>Autor</label>
            <input type="text" name="autor" placeholder="Nombre del autor"
                value="<%= typeof datos !== 'undefined' ? datos.autor : '' %>" required>

            <label>Género</label>
            <select name="genero">
                <option value="">Sin especificar</option>
                <option value="Ficción" <%= typeof datos !== 'undefined' && datos.genero === 'Ficción' ? 'selected' : '' %>>Ficción</option>
                <option value="No ficción" <%= typeof datos !== 'undefined' && datos.genero === 'No ficción' ? 'selected' : '' %>>No ficción</option>
                <option value="Fantasía" <%= typeof datos !== 'undefined' && datos.genero === 'Fantasía' ? 'selected' : '' %>>Fantasía</option>
                <option value="Ciencia ficción" <%= typeof datos !== 'undefined' && datos.genero === 'Ciencia ficción' ? 'selected' : '' %>>Ciencia ficción</option>
                <option value="Terror" <%= typeof datos !== 'undefined' && datos.genero === 'Terror' ? 'selected' : '' %>>Terror</option>
                <option value="Misterio" <%= typeof datos !== 'undefined' && datos.genero === 'Misterio' ? 'selected' : '' %>>Misterio</option>
                <option value="Romance" <%= typeof datos !== 'undefined' && datos.genero === 'Romance' ? 'selected' : '' %>>Romance</option>
                <option value="Historia" <%= typeof datos !== 'undefined' && datos.genero === 'Historia' ? 'selected' : '' %>>Historia</option>
                <option value="Biografía" <%= typeof datos !== 'undefined' && datos.genero === 'Biografía' ? 'selected' : '' %>>Biografía</option>
                <option value="Autoayuda" <%= typeof datos !== 'undefined' && datos.genero === 'Autoayuda' ? 'selected' : '' %>>Autoayuda</option>
            </select>

            <label>Estado</label>
            <select name="estado">
                <option value="pendiente" <%= typeof datos !== 'undefined' && datos.estado === 'pendiente' ? 'selected' : '' %>>Pendiente</option>
                <option value="leyendo" <%= typeof datos !== 'undefined' && datos.estado === 'leyendo' ? 'selected' : '' %>>Leyendo</option>
                <option value="terminado" <%= typeof datos !== 'undefined' && datos.estado === 'terminado' ? 'selected' : '' %>>Terminado</option>
            </select>

            <label>Valoración</label>
            <select name="valoracion">
                <option value="0" <%= typeof datos !== 'undefined' && datos.valoracion == 0 ? 'selected' : '' %>>Sin valorar</option>
                <option value="1" <%= typeof datos !== 'undefined' && datos.valoracion == 1 ? 'selected' : '' %>>★ 1</option>
                <option value="2" <%= typeof datos !== 'undefined' && datos.valoracion == 2 ? 'selected' : '' %>>★★ 2</option>
                <option value="3" <%= typeof datos !== 'undefined' && datos.valoracion == 3 ? 'selected' : '' %>>★★★ 3</option>
                <option value="4" <%= typeof datos !== 'undefined' && datos.valoracion == 4 ? 'selected' : '' %>>★★★★ 4</option>
                <option value="5" <%= typeof datos !== 'undefined' && datos.valoracion == 5 ? 'selected' : '' %>>★★★★★ 5</option>
            </select>

            <label>Fecha de inicio</label>
            <input type="date" name="fecha_inicio"
                value="<%= typeof datos !== 'undefined' ? datos.fecha_inicio || '' : '' %>">
            <p class="hint">Opcional — cuándo empezaste a leerlo</p>

            <label>Fecha de fin</label>
            <input type="date" name="fecha_fin"
                value="<%= typeof datos !== 'undefined' ? datos.fecha_fin || '' : '' %>">
            <p class="hint">Opcional — cuándo lo terminaste</p>

            <!-- 👇 Nuevo campo notas -->
            <label>Notas personales</label>
            <textarea name="notas" id="notas" placeholder="Tus impresiones sobre el libro..."><%= typeof datos !== 'undefined' ? datos.notas || '' : '' %></textarea>
            <p class="contador" id="contador">0 / 500 caracteres</p>

            <button class="btn-guardar" type="submit">💾 Guardar libro</button>
        </form>

        <a class="btn-cancelar" href="/libros">↩️ Cancelar</a>
    </div>

    <!-- Contador de caracteres en tiempo real -->
    <script>
        const textarea = document.getElementById('notas');
        const contador = document.getElementById('contador');

        textarea.addEventListener('input', () => {
            const longitud = textarea.value.length;
            contador.textContent = `${longitud} / 500 caracteres`;
            if (longitud > 500) {
                contador.classList.add('limite');
            } else {
                contador.classList.remove('limite');
            }
        });
    </script>

</body>
</html>