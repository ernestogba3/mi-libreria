<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Mi Estantería</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: Arial, sans-serif; background: #f5f0eb; min-height: 100vh; padding: 40px 20px; }
        h1 { text-align: center; color: #3d2b1f; font-size: 2rem; margin-bottom: 10px; }
        .subtitulo { text-align: center; color: #7a5c44; margin-bottom: 30px; }
        .btn-nuevo { display: block; width: fit-content; margin: 0 auto 20px; background: #3d2b1f; color: white; padding: 10px 24px; border-radius: 6px; text-decoration: none; }
        .filtros { display: flex; justify-content: center; gap: 10px; margin-bottom: 30px; }
        .filtro { padding: 6px 16px; border-radius: 20px; text-decoration: none; font-size: 0.9rem; background: #e0d6cc; color: #3d2b1f; }
        .filtro.activo { background: #3d2b1f; color: white; }
        .grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 20px; max-width: 1100px; margin: 0 auto; }
        .card { background: white; border-radius: 10px; padding: 20px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); border-left: 5px solid #3d2b1f; }
        .card h2 { color: #3d2b1f; font-size: 1.1rem; margin-bottom: 6px; }
        .card .autor { color: #7a5c44; font-size: 0.9rem; margin-bottom: 12px; }
        .badge { display: inline-block; padding: 3px 10px; border-radius: 20px; font-size: 0.8rem; font-weight: bold; margin-bottom: 10px; }
        .pendiente { background: #fdebd0; color: #d35400; }
        .leyendo { background: #d5f5e3; color: #1e8449; }
        .terminado { background: #d6eaf8; color: #1a5276; }
        .estrellas { color: #f0a500; font-size: 1.1rem; margin-bottom: 14px; }
        .acciones { display: flex; gap: 8px; }
        .btn-editar { background: #f0a500; color: white; padding: 6px 12px; border: none; border-radius: 4px; cursor: pointer; text-decoration: none; font-size: 0.85rem; }
        .btn-eliminar { background: #e74c3c; color: white; padding: 6px 12px; border: none; border-radius: 4px; cursor: pointer; font-size: 0.85rem; }
        .vacio { text-align: center; color: #7a5c44; margin-top: 60px; font-size: 1.1rem; }
    </style>
</head>
<body>

    <h1>📚 Mi Estantería</h1>
    <p class="subtitulo">Todos mis libros en un solo lugar</p>

    <a class="btn-nuevo" href="/libros/nuevo">+ Añadir libro</a>

      <!-- Botones de filtro -->
    <div class="filtros">
        <a href="/libros"class="filtro <%= !estado ? 'activo' : '' %>">Todos</a>
        <a href="/libros?estado=pendiente" class="filtro <%= estado === 'pendiente' ? 'activo' : '' %>">Pendiente</a>
        <a href="/libros?estado=leyendo" class="filtro <%= estado === 'leyendo' ? 'activo' : '' %>">Leyendo</a>
        <a href="/libros?estado=terminado" class="filtro <%= estado === 'terminado' ? 'activo' : '' %>">Terminado</a>
    </div>

    <% if (lista.length === 0) { %>
        <p class="vacio">Tu estantería está vacía, ¡añade tu primer libro!</p>
    <% } else { %>
        <div class="grid">
            <% lista.forEach(libro => { %>
                <div class="card">
                    <h2><%= libro.titulo %></h2>
                    <p class="autor"><%= libro.autor %></p>

                    <span class="badge <%= libro.estado %>"><%= libro.estado %></span>

                    <p class="estrellas">
                        <% for(let i = 1; i <= 5; i++) { %>
                            <%= i <= libro.valoracion ? '★' : '☆' %>
                        <% } %>
                    </p>

                    <div class="acciones">
                        <a class="btn-editar" href="/libros/<%= libro.id %>/editar">✏️ Editar</a>
                        <form action="/libros/<%= libro.id %>?_method=DELETE" method="POST">
                            <button class="btn-eliminar" type="submit">🗑️ Eliminar</button>
                        </form>
                    </div>
                </div>
            <% }) %>
        </div>
    <% } %>

</body>
</html>