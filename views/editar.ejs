<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>Editar Libro</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: Arial, sans-serif; background: #f5f0eb; min-height: 100vh; padding: 40px 20px; }
        h1 { text-align: center; color: #3d2b1f; margin-bottom: 30px; }
        .formulario { background: white; max-width: 500px; margin: 0 auto; padding: 30px; border-radius: 10px; box-shadow: 0 2px 8px rgba(0,0,0,0.1); }
        label { display: block; color: #3d2b1f; font-weight: bold; margin-bottom: 6px; }
        input, select { width: 100%; padding: 10px; margin-bottom: 20px; border: 1px solid #ddd; border-radius: 6px; font-size: 1rem; }
        .hint { color: #7a5c44; font-size: 0.8rem; margin-top: -16px; margin-bottom: 16px; }
        .btn-guardar { width: 100%; background: #3d2b1f; color: white; padding: 12px; border: none; border-radius: 6px; font-size: 1rem; cursor: pointer; }
        .btn-cancelar { display: block; text-align: center; margin-top: 12px; color: #7a5c44; text-decoration: none; }
    </style>
</head>
<body>

    <h1>✏️ Editar libro</h1>

    <div class="formulario">
        <form action="/libros/<%= libro.id %>?_method=PUT" method="POST">

            <label>Título</label>
            <input type="text" name="titulo" value="<%= libro.titulo %>" required>

            <label>Autor</label>
            <input type="text" name="autor" value="<%= libro.autor %>" required>

            <label>Estado</label>
            <select name="estado">
                <option value="pendiente" <%= libro.estado === 'pendiente' ? 'selected' : '' %>>Pendiente</option>
                <option value="leyendo" <%= libro.estado === 'leyendo' ? 'selected' : '' %>>Leyendo</option>
                <option value="terminado" <%= libro.estado === 'terminado' ? 'selected' : '' %>>Terminado</option>
            </select>

            <label>Valoración</label>
            <select name="valoracion">
                <option value="0" <%= libro.valoracion == 0 ? 'selected' : '' %>>Sin valorar</option>
                <option value="1" <%= libro.valoracion == 1 ? 'selected' : '' %>>★ 1</option>
                <option value="2" <%= libro.valoracion == 2 ? 'selected' : '' %>>★★ 2</option>
                <option value="3" <%= libro.valoracion == 3 ? 'selected' : '' %>>★★★ 3</option>
                <option value="4" <%= libro.valoracion == 4 ? 'selected' : '' %>>★★★★ 4</option>
                <option value="5" <%= libro.valoracion == 5 ? 'selected' : '' %>>★★★★★ 5</option>
            </select>

            <!-- 👇 Nuevos campos de fecha -->
            <label>Fecha de inicio</label>
            <input type="date" name="fecha_inicio" value="<%= libro.fecha_inicio || '' %>">
            <p class="hint">Opcional — cuándo empezaste a leerlo</p>

            <label>Fecha de fin</label>
            <input type="date" name="fecha_fin" value="<%= libro.fecha_fin || '' %>">
            <p class="hint">Opcional — cuándo lo terminaste</p>

            <button class="btn-guardar" type="submit">💾 Guardar cambios</button>
        </form>

        <a class="btn-cancelar" href="/libros">↩️ Cancelar</a>
    </div>

</body>
</html>